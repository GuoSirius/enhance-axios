{
  "name": "enhance-axios",
  "version": "1.0.0",
  "description": "axios 增强库，支持防重复提交、取消请求和失败重试",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.mjs",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    },
    "./esm": {
      "import": "./dist/esm/index.mjs"
    },
    "./esm/min": {
      "import": "./dist/esm/min/index.mjs"
    },
    "./cjs": {
      "require": "./dist/cjs/index.js"
    },
    "./cjs/min": {
      "require": "./dist/cjs/min/index.js"
    },
    "./iife": {
      "default": "./dist/iife/index.global.js"
    },
    "./iife/min": {
      "default": "./dist/iife/min/index.global.js"
    }
  },
  "unpkg": "dist/iife/min/index.global.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "example": "tsup && node example/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "keywords": [
    "axios",
    "http",
    "request",
    "prevent-duplicate",
    "cancel-request",
    "retry"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "axios": ">=1.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "axios": "^1.16.1",
    "eslint": "^10.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
