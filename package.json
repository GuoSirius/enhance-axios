{
  "name": "enhance-axios",
  "version": "1.0.0",
  "description": "axios 增强库，支持防重复提交和取消请求",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./iife": {
      "types": "./dist/index.d.ts",
      "default": "./dist/iife/index.global.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:all": "npm run build && npm run build:iife",
    "build:iife": "tsup --config iifeConfig",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "keywords": ["axios", "http", "request", "prevent-duplicate", "cancel-request"],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "axios": ">=1.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "axios": "^1.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0"
  }
}